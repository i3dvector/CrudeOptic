# Supabase — get from supabase.com project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# EIA Open Data — register free at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-key

# FRED API — register free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-key

# UN Comtrade — optional, for higher rate limits
# COMTRADE_API_KEY=your-comtrade-key

# App URL — used for server-side API calls during SSR
NEXT_PUBLIC_APP_URL=http://localhost:3000
